%%

H= simlation_Hex1.H;
Hx=squeeze(H(1,const.z2+1,:));
Hy= squeeze(H(2,const.z2+1,:));
[pks_x,locs_x] = findpeaks(Hx);
[pks_,locs_y] = findpeaks(Hy);

T_vec= [locs_x(2:end)- locs_x(1:end-1) ; locs_y(2:end)- locs_y(1:end-1)];
T= mean(T_vec);
fv= [Hx(end-1:end)';Hy(end-1: end)'];
polellip(fv);



%%

z1= const.z1;
z2= const.z2;
z_len= const.z_len;
dz= const.dz_save_file;

mat_vec= [zeros(1,z1) ones(1,z2-z1) zeros(1,z_len-z2)];
mat_vec= mat_vec(1:const.resultion:end);
time_plot_2_fields(squeeze(simlation1.H(1,:,:))',simlation1.S(:)',dz,z1,z2,3,"H_x","S_z");

%% plot momnt
dt= const.dt_save_file;
plot_moments(simlation1.ms,dt,5)

Ms= squeeze(sum(simlation1.ms,2));
T= length(Ms);

T_Global= linspace(0,dt*(T-1),T);

figure
plot(T_Global,squeeze(Ms(1,:)),'linewidth',2,'DisplayName','M_x');
hold on
plot(T_Global,squeeze(Ms(2,:)),'linewidth',2,'DisplayName','M_y');
plot(T_Global,squeeze(Ms(3,:)),'linewidth',4,'DisplayName','M_z')
plot(T_Global,squeeze(((Ms(1,:)).^2 + (Ms(2,:)).^2 + (Ms(3,:)).^2).^0.5),'linewidth',1.5,'DisplayName','Magnetization Absolute Value');

title(['all Ms , Ms size change in: 10^{' num2str(floor(log10(simlation1.ms_ratio)+1)) '} of original Value' ])
xlabel('time [sec]'), ylabel('magentizasion value [A/m]')

